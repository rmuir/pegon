{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/extension.js"
      ],
      "preLaunchTask": "Build Server and Extension",
      "env": {
        "PEGON_SERVER_PATH": "${workspaceRoot}/target/debug/pegon"
      },
      "skipFiles": [
        "<node_internals>/**/*.js"
      ]
    }
  ]
}
