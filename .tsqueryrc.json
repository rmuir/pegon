{
  "$schema": "https://raw.githubusercontent.com/ribru17/ts_query_ls/refs/heads/master/schemas/config.json",
  "parser_install_directories": [
    "${TREE_SITTER_JAVA_ORCHARD_HOME}",
    "${HOME}/workspace/tree-sitter-java-orchard",
    "."
  ],
  "supported_abi_versions": {
    "start": 13,
    "end": 15
  },
  "parser_aliases": {
    "html_tags": "html",
    "ecma": "javascript",
    "jsx": "javascript",
    "java": "java-orchard"
  },
  "valid_captures": {
    "definitions": {
      "range": "full range of the symbol",
      "selection": "identifier of the symbol, must be within @range"
    },
    "diagnostics": {
      "error": "indicates the captured node is the source of the error",
      "visible": "indicates the captured node is relevant and should be visible",
      "context": "indicates captured node should be highlighted"
    },
    "highlights": {
      "range": "range of the area for the symbol",
      "reference": "reference to another symbol that should be highlighted"
    },
    "folds": {
      "range": "range of the folding region"
    },
    "hints": {
      "label": "components of inlay hint text",
      "location": "source location for interactive features (hover/go-to-definition)",
      "position": "location after which inlay hint should start"
    },
    "hover": {
      "range": "range of the hover area for the symbol"
    },
    "injections": {
      "injection.content": "indicates that the captured node should have its contents re-parsed using another language",
      "injection.language": "indicates that the captured node\u2019s text may contain the name of a language that should be used to re-parse the `@injection.content`"
    },
    "scopes": {
      "definition": "identifier that becomes valid within scope",
      "start": "beginning of the scope range",
      "end": "end of the scope range"
    },
    "symbols": {
      "range": "full range of the symbol",
      "selection": "identifier of the symbol, must be within @range",
      "marker": "marker annotations such as @Deprecated, @Override",
      "signature": "additional components of symbols name such as method signature",
      "detail": "additional symbol detail such as type, type-parameters"
    },
    "tokens": {
      "range": "full range of the symbol"
    }
  },
  "valid_predicates": {
    "eq": {
      "any": true,
      "parameters": [
        {
          "type": "capture",
          "arity": "required"
        },
        {
          "type": "any",
          "arity": "required"
        }
      ],
      "description": "checks for equality between two nodes, or a node and a string"
    },
    "eol": {
      "not": false,
      "parameters": [
        {
          "type": "capture",
          "arity": "required"
        }
      ],
      "description": "true if the node ends with a newline"
    },
    "lt": {
      "not": false,
      "parameters": [
        {
          "type": "capture",
          "arity": "required"
        },
        {
          "type": "capture",
          "arity": "required"
        }
      ],
      "description": "utf-8 comparison between two nodes"
    },
    "any-of": {
      "parameters": [
        {
          "type": "capture",
          "arity": "required"
        },
        {
          "type": "string",
          "arity": "required"
        },
        {
          "type": "string",
          "arity": "required"
        },
        {
          "type": "string",
          "arity": "variadic"
        }
      ],
      "description": "match any of the given strings against the text corresponding to a node"
    },
    "match": {
      "any": true,
      "parameters": [
        {
          "type": "capture",
          "arity": "required"
        },
        {
          "type": "string",
          "arity": "required"
        }
      ],
      "description": "Match a regexp against the text corresponding to a node"
    }
  },
  "valid_directives": {
    "set": {
      "parameters": [
        {
          "type": "string",
          "arity": "required",
          "constraint": {
            "enum": [
              "diagnostic.context.label",
              "diagnostic.fix",
              "diagnostic.help",
              "diagnostic.label",
              "diagnostic.name",
              "diagnostic.severity",
              "diagnostic.title",
              "fold.kind",
              "fold.lineoffset",
              "hint.prefix",
              "hint.suffix",
              "hint.pad.left",
              "hint.pad.medial",
              "hint.pad.right",
              "hover.kind",
              "hover.spec",
              "hover.description",
              "highlight.kind",
              "scope.type",
              "scope.start.inclusive",
              "symbol.kind",
              "token.type",
              "token.modifiers",
              "token.scoped"
            ]
          }
        },
        {
          "type": "any",
          "arity": "optional"
        },
        {
          "type": "any",
          "arity": "optional"
        }
      ],
      "description": "sets key/value metadata for a specific match or capture"
    }
  }
}
